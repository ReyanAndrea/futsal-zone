    {{-- Flash Messages --}}
    @if(flashMessages.has('error'))
      <div class="bg-red-50 border-l-4 border-red-500 text-red-700 px-8 py-4 text-sm flex items-center gap-2">
        ❌ {{ flashMessages.get('error') }}
      </div>
    @end
    @if(flashMessages.has('success'))
      <div class="bg-green-50 border-l-4 border-green-500 text-green-700 px-8 py-4 text-sm flex items-center gap-2">
        ✅ {{ flashMessages.get('success') }}
      </div>
    @end

    <main class="flex-1 px-8 py-8">
      {{{ await $slots.main() }}}
    </main>

