@layout('admin/layout')

@slot('main')
  <div class="max-w-2xl">

    <div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Tambah Lapangan</h1>
  <div class="flex gap-2">
    <a href="/admin/lapangan" class="text-gray-400 hover:text-gray-600 transition text-sm">
      ← Kembali ke Lapangan
    </a>
    <span class="text-gray-300">|</span>
    <a href="/admin/dashboard" class="text-gray-400 hover:text-gray-600 transition text-sm">
