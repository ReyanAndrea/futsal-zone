<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Login - FutsalZone</title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
</head>
<body class="bg-gradient-to-br from-green-900 to-green-700 min-h-screen flex items-center justify-center">

  <div class="bg-white rounded-3xl shadow-2xl p-10 w-full max-w-md">

    <div class="text-center mb-8">
      <div class="text-5xl mb-3">⚽</div>
      <h1 class="text-3xl font-extrabold text-green-700">FutsalZone</h1>
      <p class="text-gray-400 mt-1 text-sm">Masuk ke panel admin</p>
    </div>

    @if(flashMessages.has('error'))
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-5 text-sm flex items-center gap-2">
        ❌ {{ flashMessages.get('error') }}
      </div>
    @end

    <form action="/admin/login" method="POST">
      {{ csrfField() }}

      <div class="mb-5">
        <label class="block text-gray-600 font-semibold mb-2 text-sm">Email</label>
        <input type="email" name="email" required
          class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50"
          placeholder="admin@futsalzone.com" />
      </div>

      <div class="mb-8">
        <label class="block text-gray-600 font-semibold mb-2 text-sm">Password</label>
        <input type="password" name="password" required
          class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50"
          placeholder="••••••••" />
      </div>

      <button type="submit"
        class="w-full bg-gradient-to-r from-green-700 to-green-600 text-white py-4 rounded-2xl font-bold text-lg hover:from-green-800 hover:to-green-700 transition shadow-md">
        Masuk ke Dashboard
      </button>
    </form>

    <a href="/" class="block text-center text-gray-400 mt-6 hover:text-gray-600 transition text-sm">
      ← Kembali ke Website
    </a>

  </div>

</body>
</html>